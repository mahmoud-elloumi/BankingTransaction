{\pard\qc\sb400
{\f0\fs52\b\cf1 \u55357?\u56422? TransactFlow}\par
{\f0\fs28\cf9 Syst\'e8me de Transactions Bancaires en Temps R\'e9el}\par\sb200
{\f0\fs22 Propuls\'e9 par Apache Kafka \u8212? Java 17}\par\sb400
{\f0\fs20\b Pr\'e9sent\'e9 par :} {\f0\fs20 Mahmoud}\par
{\f0\fs20\b Date :} {\f0\fs20 Mars 2026}\par
}

\page

{\pard\sb300{\f0\fs32\b\cf1 Slide 2 \u8212? \u10067? Probl\'e9matique}\par}
{\pard\sb200{\f0\fs22 Les banques traitent des milliers de transactions par seconde. Comment :}\par}
{\pard\li400\sb100{\f0\fs22 \u8226? Traiter les transactions en {\b temps r\'e9el} ?}\par}
{\pard\li400{\f0\fs22 \u8226? D\'e9tecter les fraudes {\b imm\'e9diatement} ?}\par}
{\pard\li400{\f0\fs22 \u8226? Notifier les clients {\b instantan\'e9ment} ?}\par}
{\pard\li400{\f0\fs22 \u8226? Garder une {\b tra\'e7abilit\'e9 compl\'e8te} ?}\par}
{\pard\sb200{\f0\fs22\b\cf1 \u8594? Solution : Architecture Event-Driven avec Apache Kafka}\par}

\page

{\pard\sb300{\f0\fs32\b\cf1 Slide 3 \u8212? \u127919? Objectifs du Projet}\par}
{\pard\li400\sb150{\f0\fs22 \u9989? Produire des transactions bancaires en temps r\'e9el}\par}
{\pard\li400{\f0\fs22 \u9989? Valider automatiquement selon des r\'e8gles m\'e9tier}\par}
{\pard\li400{\f0\fs22 \u9989? D\'e9tecter les fraudes instantan\'e9ment}\par}
{\pard\li400{\f0\fs22 \u9989? Notifier par email (approuv\'e9 / rejet\'e9 / fraude)}\par}
{\pard\li400{\f0\fs22 \u9989? Auditer toutes les op\'e9rations dans un fichier CSV}\par}
{\pard\li400{\f0\fs22 \u9989? Visualiser via un dashboard web moderne}\par}

\page

{\pard\sb300{\f0\fs32\b\cf1 Slide 4 \u8212? \u128296? Technologies Utilis\'e9es}\par}
{\pard\sb200{\f0\fs24\b Backend :}\par}
{\pard\li400\sb100{\f0\fs22 \u8226? {\b Java 17+} \u8594? Langage principal}\par}
{\pard\li400{\f0\fs22 \u8226? {\b Apache Kafka 3.9.0} \u8594? Messaging temps r\'e9el (Mode KRaft)}\par}
{\pard\li400{\f0\fs22 \u8226? {\b Jackson 2.16.1} \u8594? S\'e9rialisation JSON}\par}
{\pard\li400{\f0\fs22 \u8226? {\b Jakarta Mail 2.0.1} \u8594? Notifications email SMTP Gmail}\par}
{\pard\li400{\f0\fs22 \u8226? {\b SLF4J + Logback} \u8594? Logging}\par}
{\pard\li400{\f0\fs22 \u8226? {\b Maven 3.x} \u8594? Build + D\'e9pendances (Fat JAR)}\par}
{\pard\sb150{\f0\fs24\b Frontend :}\par}
{\pard\li400\sb100{\f0\fs22 \u8226? HTML5 / CSS3 / JavaScript Vanilla}\par}
{\pard\li400{\f0\fs22 \u8226? Dark Theme moderne (TransactFlow)}\par}
{\pard\li400{\f0\fs22 \u8226? Responsive Design + Animations CSS + Glassmorphism}\par}

\page

{\pard\sb300{\f0\fs32\b\cf1 Slide 5 \u8212? \u127959? Architecture Globale}\par}
{\pard\sb200{\f0\fs22 Le syst\'e8me est compos\'e9 de 3 couches principales :}\par}
{\pard\sb200{\f0\fs24\b 1. Couche Client (Navigateur)}\par}
{\pard\li400{\f0\fs22 \u8226? Dashboard web accessible sur http://localhost:8080}\par}
{\pard\li400{\f0\fs22 \u8226? Interface utilisateur moderne TransactFlow}\par}
{\pard\sb150{\f0\fs24\b 2. Couche Serveur (Java 17)}\par}
{\pard\li400{\f0\fs22 \u8226? DashboardServer : HTTP Server + API REST + Kafka Producer/Consumer}\par}
{\pard\li400{\f0\fs22 \u8226? Authentification avec tokens UUID}\par}
{\pard\sb150{\f0\fs24\b 3. Couche Kafka (Port 9092 - Mode KRaft)}\par}
{\pard\li400{\f0\fs22 \u8226? 4 Topics d\'e9di\'e9s}\par}
{\pard\li400{\f0\fs22 \u8226? 4 Consumers ind\'e9pendants}\par}
{\pard\li400{\f0\fs22 \u8226? Fan-Out Pattern}\par}

\page

{\pard\sb300{\f0\fs32\b\cf1 Slide 6 \u8212? \u128225? Les 4 Topics Kafka}\par}
{\pard\sb200{\f0\fs24\b\cf4 1. bank.transactions.pending}\par}
{\pard\li400{\f0\fs22 \u8594? Point d\'27entr\'e9e de toutes les transactions}\par}
{\pard\li400{\f0\fs22 \u8594? Producteur : DashboardServer}\par}
{\pard\li400{\f0\fs22 \u8594? Consomm\'e9 par : TransactionConsumer + FraudDetectionConsumer}\par}
{\pard\sb150{\f0\fs24\b\cf4 2. bank.transactions.approved}\par}
{\pard\li400{\f0\fs22 \u8594? Transactions valid\'e9es avec succ\'e8s}\par}
{\pard\li400{\f0\fs22 \u8594? Consomm\'e9 par : NotificationConsumer + AuditLogConsumer}\par}
{\pard\sb150{\f0\fs24\b\cf5 3. bank.transactions.rejected}\par}
{\pard\li400{\f0\fs22 \u8594? Transactions refus\'e9es (r\'e8gles m\'e9tier non respect\'e9es)}\par}
{\pard\li400{\f0\fs22 \u8594? Consomm\'e9 par : NotificationConsumer + AuditLogConsumer}\par}
{\pard\sb150{\f0\fs24\b\cf5 4. bank.transactions.fraud}\par}
{\pard\li400{\f0\fs22 \u8594? Transactions suspectes d\'e9tect\'e9es}\par}
{\pard\li400{\f0\fs22 \u8594? Consomm\'e9 par : NotificationConsumer + AuditLogConsumer}\par}
{\pard\sb200{\f0\fs22\b\cf1 Concept cl\'e9 \u8212? Fan-Out Pattern : Un m\'eame message lu par plusieurs Consumer Groups simultan\'e9ment.}\par}

\page

{\pard\sb300{\f0\fs32\b\cf1 Slide 7 \u8212? \u9881? Les 4 Consumers Kafka}\par}
{\pard\sb200{\f0\fs24\b 1. TransactionConsumer}\par}
{\pard\li400{\f0\fs22 \u8226? Group ID : bank-transaction-validator}\par}
{\pard\li400{\f0\fs22 \u8226? R\'f4le : Validation des r\'e8gles m\'e9tier}\par}
{\pard\li400{\f0\fs22 \u8226? Topic \'e9cout\'e9 : bank.transactions.pending}\par}
{\pard\sb150{\f0\fs24\b 2. FraudDetectionConsumer}\par}
{\pard\li400{\f0\fs22 \u8226? Group ID : bank-fraud-detector}\par}
{\pard\li400{\f0\fs22 \u8226? R\'f4le : D\'e9tection de fraude en temps r\'e9el (4 r\'e8gles)}\par}
{\pard\li400{\f0\fs22 \u8226? Topic \'e9cout\'e9 : bank.transactions.pending}\par}
{\pard\sb150{\f0\fs24\b 3. NotificationConsumer}\par}
{\pard\li400{\f0\fs22 \u8226? Group ID : bank-notification-service}\par}
{\pard\li400{\f0\fs22 \u8226? R\'f4le : Envoi d\'27emails SMTP Gmail}\par}
{\pard\li400{\f0\fs22 \u8226? Topics \'e9cout\'e9s : approved + rejected + fraud}\par}
{\pard\sb150{\f0\fs24\b 4. AuditLogConsumer}\par}
{\pard\li400{\f0\fs22 \u8226? Group ID : bank-audit-logger}\par}
{\pard\li400{\f0\fs22 \u8226? R\'f4le : Journal d\'27audit CSV}\par}
{\pard\li400{\f0\fs22 \u8226? Topics \'e9cout\'e9s : approved + rejected + fraud}\par}

\page

{\pard\sb300{\f0\fs32\b\cf1 Slide 8 \u8212? \u10004? Validation des Transactions}\par}
{\pard\sb200{\f0\fs22 TransactionConsumer applique 4 r\'e8gles de validation :}\par}
{\pard\sb200{\f0\fs22\b R\'e8gle 1 \u8212? Montant positif}\par}
{\pard\li400{\f0\fs22 Condition : amount <= 0 \u8594? {\b\cf5 REJECTED}}\par}
{\pard\sb150{\f0\fs22\b R\'e8gle 2 \u8212? Limite maximale}\par}
{\pard\li400{\f0\fs22 Condition : amount > 50 000\u8364? \u8594? {\b\cf5 REJECTED}}\par}
{\pard\sb150{\f0\fs22\b R\'e8gle 3 \u8212? Exp\'e9diteur requis}\par}
{\pard\li400{\f0\fs22 Condition : senderId == null \u8594? {\b\cf5 REJECTED}}\par}
{\pard\sb150{\f0\fs22\b R\'e8gle 4 \u8212? Transaction valide}\par}
{\pard\li400{\f0\fs22 Toutes les r\'e8gles passent \u8594? {\b\cf4 APPROVED}}\par}
{\pard\sb200{\f0\fs22\b Configuration du Consumer :}\par}
{\pard\li400{\f0\fs22 \u8226? ENABLE_AUTO_COMMIT = false \u8594? Commit manuel (aucune transaction perdue)}\par}
{\pard\li400{\f0\fs22 \u8226? AUTO_OFFSET_RESET = earliest \u8594? Lit depuis le d\'e9but}\par}
{\pard\li400{\f0\fs22 \u8226? MAX_POLL_RECORDS = 50 \u8594? Max 50 messages par poll}\par}

\page

{\pard\sb300{\f0\fs32\b\cf1 Slide 9 \u8212? \u128680? D\'e9tection de Fraude}\par}
{\pard\sb200{\f0\fs22 FraudDetectionConsumer \u8212? 4 r\'e8gles de scoring :}\par}
{\pard\sb200{\f0\fs22\b\cf5 R\'e8gle 1 \u8212? Montant \'c9lev\'e9 (HIGH RISK)}\par}
{\pard\li400{\f0\fs22 amount > 10 000\u8364? \u8594? Alerte imm\'e9diate}\par}
{\pard\sb150{\f0\fs22\b\cf6 R\'e8gle 2 \u8212? V\'e9locit\'e9 (MEDIUM RISK)}\par}
{\pard\li400{\f0\fs22 Plus de 3 transactions en 60 secondes depuis le m\'eame compte}\par}
{\pard\li400{\f0\fs22 Algorithme : ConcurrentHashMap + fen\'eatre glissante de 60 secondes}\par}
{\pard\sb150{\f0\fs22\b\cf4 R\'e8gle 3 \u8212? Montant Rond Suspect (LOW RISK)}\par}
{\pard\li400{\f0\fs22 amount >= 5000 ET multiple de 1000}\par}
{\pard\sb150{\f0\fs22\b\cf4 R\'e8gle 4 \u8212? Destinataire Inconnu (LOW RISK)}\par}
{\pard\li400{\f0\fs22 Transfer vers un compte non whitelist\'e9}\par}
{\pard\sb200{\f0\fs22\b\cf1 \u8594? Si au moins 1 r\'e8gle d\'e9clench\'e9e \u8594? Publication vers bank.transactions.fraud}\par}

\page

{\pard\sb300{\f0\fs32\b\cf1 Slide 10 \u8212? \u128140? Notifications Email}\par}
{\pard\sb200{\f0\fs22 NotificationConsumer \u8212? SMTP Gmail :}\par}
{\pard\sb150{\f0\fs24\b\cf4 bank.transactions.approved \u8594? Email de confirmation}\par}
{\pard\li400{\f0\fs22 Objet : "Votre transaction a \'e9t\'e9 approuv\'e9e"}\par}
{\pard\li400{\f0\fs22 Contenu : D\'e9tails de la transaction + montant + b\'e9n\'e9ficiaire}\par}
{\pard\sb150{\f0\fs24\b\cf5 bank.transactions.rejected \u8594? Notification de rejet}\par}
{\pard\li400{\f0\fs22 Objet : "Votre transaction a \'e9t\'e9 rejet\'e9e"}\par}
{\pard\li400{\f0\fs22 Contenu : Raison du rejet + conseils}\par}
{\pard\sb150{\f0\fs24\b\cf5 bank.transactions.fraud \u8594? Alerte fraude urgente}\par}
{\pard\li400{\f0\fs22 Objet : "ALERTE : Transaction suspecte d\'e9tect\'e9e"}\par}
{\pard\li400{\f0\fs22 Contenu : D\'e9tails de la fraude + niveau de risque}\par}
{\pard\sb200{\f0\fs22\b Configuration SMTP :}\par}
{\pard\li400{\f0\fs22 \u8226? Host : smtp.gmail.com | Port : 587 (STARTTLS)}\par}
{\pard\li400{\f0\fs22 \u8226? Auth : App Password Google}\par}
{\pard\li400{\f0\fs22 \u8226? Email r\'e9ception : projetpfa26@gmail.com}\par}

\page

{\pard\sb300{\f0\fs32\b\cf1 Slide 11 \u8212? \u128203? Audit Log}\par}
{\pard\sb200{\f0\fs22 AuditLogConsumer \u8212? Journal de tra\'e7abilit\'e9 complet :}\par}
{\pard\sb150{\f0\fs22 Fichier g\'e9n\'e9r\'e9 : {\b audit-log.csv}}\par}
{\pard\sb150{\f0\fs22 Format des colonnes :}\par}
{\pard\li400{\f0\fs22\f1 AuditTimestamp | TransactionId | SenderId | ReceiverId}\par}
{\pard\li400{\f0\fs22\f1 Amount | Currency | Type | Status | Topic | Description}\par}
{\pard\sb150{\f0\fs22 Exemple de ligne :}\par}
{\pard\li400{\f0\fs22\f1 2026-03-29 14:35:22 | tx-1234 | ACC-001 | ACC-002 | 1500.00 | EUR | TRANSFER | APPROVED}\par}
{\pard\sb200{\f0\fs22\b Points techniques :}\par}
{\pard\li400{\f0\fs22 \u8226? Mode APPEND : Aucune donn\'e9e perdue}\par}
{\pard\li400{\f0\fs22 \u8226? AUTO_OFFSET_RESET = earliest : Lit depuis le d\'e9but}\par}
{\pard\li400{\f0\fs22 \u8226? Conformit\'e9 bancaire : 100% des transactions trac\'e9es}\par}

\page

