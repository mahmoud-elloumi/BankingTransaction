{\pard\sb300{\f0\fs32\b\cf1 Slide 14 \u8212? \u128218? Concepts Kafka D\'e9montr\'e9s}\par}
{\pard\sb200{\f0\fs22\b 1. TOPIC} {\f0\fs22 \u8594? 4 topics d\'e9di\'e9s : pending, approved, rejected, fraud}\par}
{\pard\sb100{\f0\fs22\b 2. PARTITION} {\f0\fs22 \u8594? Cl\'e9 = senderId \u8594? ordre garanti par compte}\par}
